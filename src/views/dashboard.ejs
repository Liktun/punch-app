<%- include('_head') %>
<div class="card">
  <h1>Bonjour, <%= user.full_name %></h1>
  <% if (flash) { %><div class="flash <%= flash.type === 'ok' ? 'ok' : 'warn' %>"><%= flash.msg %></div><% } %>

  <div class="clock" id="clock" data-now="<%= Date.now() %>">--:--:--</div>

  <div class="status">
    <% if (open) { %>
      <p class="badge in">
        Quart en cours depuis <strong><%= fmtTime(open.clock_in) %></strong><br>
        <span class="ticker" id="ticker" data-start="<%= new Date(open.clock_in).getTime() %>">0h00</span> travaillées
      </p>
      <form action="/punch/out" method="post" onsubmit="return confirm('Confirmer ton départ ?');">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button class="btn danger big" type="submit">Puncher mon départ</button>
      </form>
    <% } else { %>
      <p class="badge out">Aucun quart en cours</p>
      <form action="/punch/in" method="post" onsubmit="return confirm('Confirmer ton arrivée ?');">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button class="btn primary big" type="submit">Puncher mon arrivée</button>
      </form>
    <% } %>
  </div>

  <div class="period-box">
    <span>Période courante : <strong><%= periodLabel %></strong></span>
    <span class="total">Total net : <strong><%= periodNet %></strong></span>
  </div>
  <div class="stat-grid">
    <div class="stat"><span class="stat-label">Régulières</span><span class="stat-val"><%= periodRegular %></span></div>
    <% if (hasOvertime) { %>
    <div class="stat ot"><span class="stat-label">Heures supp.</span><span class="stat-val"><%= periodOvertime %></span></div>
    <% } %>
    <div class="stat"><span class="stat-label">Pauses déduites</span><span class="stat-val"><%= periodBreak %></span></div>
  </div>
</div>

<div class="card">
  <h2>Mes derniers punchs</h2>
  <table>
    <thead><tr><th>Arrivée</th><th>Départ</th><th>Durée</th></tr></thead>
    <tbody>
      <% if (recent.length === 0) { %>
        <tr><td colspan="3" class="muted">Aucun punch encore.</td></tr>
      <% } %>
      <% recent.forEach((p) => { %>
        <tr>
          <td><%= fmtTime(p.clock_in) %></td>
          <td><%= p.clock_out ? fmtTime(p.clock_out) : '— en cours' %></td>
          <td><%= p.clock_out ? fmtHours(new Date(p.clock_out) - new Date(p.clock_in)) : '—' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<script src="/dashboard.js"></script>
<%- include('_foot') %>

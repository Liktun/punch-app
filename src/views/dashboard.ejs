<%- include('_head') %>

<% if (flash) { %><div class="flash <%= flash.type === 'ok' ? 'ok' : 'warn' %> flash-float"><%= flash.msg %></div><% } %>

<section class="hero">
  <p class="greeting" id="greeting">Bonjour, <%= user.full_name.split(' ')[0] %> 👋</p>

  <div class="punch-card <%= open ? 'is-open' : 'is-closed' %>">
    <div class="clock-big" id="clock">--:--:--</div>

    <% if (open) { %>
      <div class="shift-state">
        <span class="live-dot"></span>
        <span>Quart en cours</span>
      </div>
      <div class="worked-now">
        <span class="worked-val" id="ticker" data-start="<%= new Date(open.clock_in).getTime() %>">0h00</span>
        <span class="worked-label">depuis <%= fmtTimeOnly(open.clock_in) %></span>
      </div>
      <form action="/punch/out" method="post" onsubmit="return confirm('Confirmer ton départ ?');">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button class="punch-btn out" type="submit">
          <span class="punch-btn-icon">■</span> Puncher mon départ
        </button>
      </form>
    <% } else { %>
      <div class="shift-state idle">
        <span>Prêt à commencer</span>
      </div>
      <div class="worked-now">
        <span class="worked-label">Aucun quart en cours</span>
      </div>
      <form action="/punch/in" method="post" onsubmit="return confirm('Confirmer ton arrivée ?');">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button class="punch-btn in" type="submit">
          <span class="punch-btn-icon">▶</span> Puncher mon arrivée
        </button>
      </form>
    <% } %>
  </div>
</section>

<section class="card period-summary">
  <div class="summary-head">
    <span class="summary-title">Cette période de paie</span>
    <span class="summary-sub"><%= periodLabel %></span>
  </div>
  <div class="big-total">
    <span class="big-total-val"><%= periodNet %></span>
    <span class="big-total-label">net travaillées</span>
  </div>
  <div class="chips">
    <span class="chip"><span class="chip-dot reg"></span><%= periodRegular %> régulières</span>
    <% if (hasOvertime) { %><span class="chip"><span class="chip-dot ot"></span><%= periodOvertime %> supp.</span><% } %>
    <% if (periodBreak !== '0h00') { %><span class="chip"><span class="chip-dot brk"></span><%= periodBreak %> pauses</span><% } %>
    <span class="chip muted-chip"><%= periodShifts %> quart<%= periodShifts > 1 ? 's' : '' %></span>
  </div>
</section>

<section class="card">
  <h2 class="section-title">Mes derniers punchs</h2>
  <% if (recent.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">🗓️</div>
      <p>Aucun punch pour l'instant.<br>Ton premier quart apparaîtra ici.</p>
    </div>
  <% } else { %>
    <ul class="punch-list">
      <% recent.forEach((p) => { %>
        <li class="punch-item">
          <div class="punch-when">
            <span class="punch-day"><%= fmtDayShort(p.clock_in) %></span>
            <span class="punch-times">
              <%= fmtTimeOnly(p.clock_in) %>
              <span class="punch-arrow">→</span>
              <%= p.clock_out ? fmtTimeOnly(p.clock_out) : 'en cours' %>
            </span>
          </div>
          <div class="punch-dur">
            <% if (p.clock_out) { %>
              <span class="dur-pill"><%= fmtHours(new Date(p.clock_out) - new Date(p.clock_in)) %></span>
            <% } else { %>
              <span class="dur-pill live"><span class="live-dot small"></span> en cours</span>
            <% } %>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<script src="/dashboard.js"></script>
<%- include('_foot') %>

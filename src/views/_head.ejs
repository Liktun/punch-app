<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pointo — Gestion des heures</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<header class="topbar">
  <a href="/" class="brand">⏱ Pointo</a>
  <nav>
    <% if (typeof user !== 'undefined' && user) { %>
      <% if (user.is_admin) { %>
        <a href="/admin">Rapport</a>
        <a href="/admin/employees">Employés</a>
      <% } else { %>
        <a href="/dashboard">Mon punch</a>
      <% } %>
      <span class="who"><%= user.full_name %></span>
      <form action="/logout" method="post" class="inline">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <button class="btn ghost">Déconnexion</button>
      </form>
    <% } %>
  </nav>
</header>
<main class="wrap <%= typeof wrapClass !== 'undefined' ? wrapClass : '' %>">

# Copy to .env on the server. NEVER commit the real .env.
PORT=3000
NODE_ENV=production

# Session secret — generate a long random string on the server:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Admin account (created/updated on boot from these values)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong

# Pay period configuration (bi-weekly / aux 2 semaines)
# ANCHOR = start date (Monday) of any known pay period, ISO YYYY-MM-DD
PAY_PERIOD_ANCHOR=2026-01-05
PAY_PERIOD_DAYS=14

# Timezone for punch timestamps and period boundaries
TZ=America/Toronto

# Auto break deduction: if a single shift is longer than BREAK_THRESHOLD_MIN,
# deduct BREAK_DEDUCTION_MIN minutes from it. Set BREAK_DEDUCTION_MIN=0 to disable.
BREAK_THRESHOLD_MIN=360
BREAK_DEDUCTION_MIN=30

# Overtime: hours worked beyond OVERTIME_WEEKLY_HOURS in a single week (Mon-Sun)
# count as overtime (displayed separately, at OVERTIME_RATE for info).
OVERTIME_WEEKLY_HOURS=40
OVERTIME_RATE=1.5

# Path to the SQLite database file (kept outside the repo)
DB_PATH=./data/punch.sqlite
